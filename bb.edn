{:tasks
 {:init (def default-task "help")

  help
  {:doc "Show available tasks"
   :task (do
           (println "registry-api — Clojure K8s starter\n")
           (println "Usage: bb <task>\n")
           (println "  Development:")
           (println "    run            Run the API locally")
           (println "    repl           Start nREPL with dev tools")
           (println "    test-request   Hit the ping endpoint")
           (println)
           (println "  Quality:")
           (println "    smoke          Require all namespaces (compile check)")
           (println "    lint           Run clj-kondo linter")
           (println "    fmt-check      Check formatting with cljfmt")
           (println "    fmt            Auto-format with cljfmt")
           (println "    check          Run lint + fmt-check + smoke")
           (println)
           (println "  Build & Deploy:")
           (println "    uberjar        Build the uberjar")
           (println "    image-build    Build container image")
           (println "    image-run      Run container locally")
           (println "    startup-time   Measure startup for K8s probe config")
           (println)
           (println "  Housekeeping:")
           (println "    clean          Remove build/cache artifacts"))}

  run
  {:doc "Run the API locally"
   :task (shell "clojure -M:run")}

  repl
  {:doc "Start nREPL with dev tools"
   :task (shell "clojure -M:dev:nrepl")}

  smoke
  {:doc "Require all src + dev namespaces (quick compile/sanity check)"
   :task (shell "clj" "-M:dev" "-e"
                "(run! require (mapcat (fn [d] (->> (file-seq (clojure.java.io/file d)) (filter #(.endsWith (.getName %) \".clj\")) (map #(-> (.getPath %) (clojure.string/replace d \"\") (subs 1) (clojure.string/replace \"/\" \".\") (clojure.string/replace \"_\" \"-\") (clojure.string/replace \".clj\" \"\") symbol)))) [\"src\" \"dev\"]))")}

  lint
  {:doc "Run clj-kondo on source and dev namespaces"
   :task (shell "clj-kondo --lint src dev")}

  fmt-check
  {:doc "Check Clojure formatting with cljfmt"
   :task (shell "cljfmt check src dev")}

  fmt
  {:doc "Format Clojure files in place with cljfmt"
   :task (shell "cljfmt fix src dev")}

  check
  {:doc "Run quick project checks (lint + format + smoke)"
   :depends [lint fmt-check smoke]}

  uberjar
  {:doc "Build the uberjar"
   :task (shell "clojure -T:build uber")}

  test-request
  {:doc "Hit the ping endpoint"
   :task (shell "curl -i http://localhost:8080/api/ping")}

  image-build
  {:doc "Build container image"
   :task (shell "docker build -t registry-api:0.1.0 .")}

  image-run
  {:doc "Run container locally"
   :task (shell "docker run --rm -p 8080:8080 registry-api:0.1.0")}

  startup-time
  {:doc "Measure app startup time for K8s probe initialDelaySeconds"
   :requires ([babashka.http-client :as http])
   :task
   (let [port   8080
         url    (str "http://localhost:" port "/health")
         start  (System/currentTimeMillis)
         proc   (babashka.process/process
                 ["clojure" "-M:run"]
                 {:out :inherit :err :inherit})
         ready? (fn []
                  (try
                    (let [resp (http/get url {:timeout 500
                                              :throw false})]
                      (= 200 (:status resp)))
                    (catch Exception _ false)))]
     (loop []
       (if (ready?)
         (let [ms (- (System/currentTimeMillis) start)
               s  (/ ms 1000.0)]
           (println)
           (println (str "✓ App responded on " url " after " s "s (" ms "ms)"))
           (println)
           (println "Suggested K8s probe settings:")
           (println (str "  initialDelaySeconds: " (long (Math/ceil s))))
           (println (str "  periodSeconds:       5"))
           (println (str "  failureThreshold:    3"))
           (babashka.process/destroy-tree proc))
         (if (> (- (System/currentTimeMillis) start) 60000)
           (do
             (println "✗ App did not respond within 60s")
             (babashka.process/destroy-tree proc)
             (System/exit 1))
           (do
             (Thread/sleep 250)
             (recur))))))}

  clean
  {:doc "Remove common local build/cache artifacts"
   :task (shell "rm -rf .cpcache target .bb .clj-kondo/.cache")}}}
